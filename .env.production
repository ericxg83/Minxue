# ============================================
# 敏学App V3 前端生产环境配置
# Cloudflare Pages 部署时使用
# ============================================

# ------------------ API 配置 ------------------
# Render 后端 API 地址
VITE_API_URL=https://minxue-api.onrender.com/api

# ------------------ OSS CDN 配置 ------------------
# 阿里 OSS CDN 域名（用于图片加速）
VITE_OSS_CDN_DOMAIN=https://minxue-app-oss.oss-cn-shanghai.aliyuncs.com

# ------------------ Supabase 配置 (兼容层) ------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your-anon-key

# ------------------ AI 服务配置 ------------------
VITE_AI_API_KEY=your-ai-api-key
VITE_AI_ENDPOINT=https://api-inference.modelscope.cn/v1/chat/completions
VITE_AI_MODEL=Qwen/Qwen3-VL-8B-Instruct

# ------------------ 应用环境标识 ------------------
VITE_APP_ENV=production
