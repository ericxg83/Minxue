# ============================================
# 敏学App V3 环境变量配置 (示例)
# ============================================

# ------------------ 数据库配置 ------------------
# Neon PostgreSQL (主要数据库)
NEON_DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-late-sun-aosak7tj-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ------------------ 对象存储配置 ------------------
# 阿里 OSS
OSS_REGION=oss-cn-shanghai
OSS_BUCKET=your-oss-bucket
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
OSS_CDN_DOMAIN=https://your-bucket.oss-cn-shanghai.aliyuncs.com

# ------------------ AI 服务配置 ------------------
AI_API_KEY=your-ai-api-key
AI_ENDPOINT=https://api-inference.modelscope.cn/v1/chat/completions
AI_MODEL=Qwen/Qwen3-VL-8B-Instruct

# 备用2 API（魔搭 ModelScope 第二把 Key，同一端点独立免费额度；可选）
# MODELSCOPE_BACKUP_API_KEY=your-second-modelscope-key
# MODELSCOPE_BACKUP_MODEL=Qwen/Qwen3-VL-8B-Instruct

# ------------------ Redis 配置 ------------------
# 本地 Redis（开发用，设置为 true 启用）
REDIS_LOCAL=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_LOCAL_PASSWORD=

# Upstash（云端 Redis，免费额度 50 万次/月）
# 主用实例：RESILIENT 优先级最高，限额耗尽时自动切换到 REDIS_POOL_URLS 里的备用实例。
REDIS_URL=redis://default:your-password@your-redis-host.upstash.io:6379

# 备用实例池（逗号分隔，用于多个 Upstash 账号自动故障转移）
# 旧账号限额已满时填在这里；当前主用实例限额耗尽会自动尝试备用。
REDIS_POOL_URLS=redis://default:pass-old@old-host.upstash.io:6379

# 调优：降低 Redis 请求量（空闲 Worker 轮询间隔，秒；默认 60）
# REDIS_DRAIN_DELAY=60
# REDIS_STALLED_INTERVAL=300000

# ------------------ 服务器配置 ------------------
PORT=3001
NODE_ENV=development

# ------------------ 任务队列配置 ------------------
MAX_RETRIES=3
TASK_TIMEOUT_MS=1800000
CONCURRENCY=2
