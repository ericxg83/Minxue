# ============================================
# 敏学App V3 后端环境变量配置
# 复制为 .env 后填入实际值
# ============================================

# ------------------ 数据库配置 ------------------
# Neon PostgreSQL (主要数据库)
NEON_DATABASE_URL=postgresql://username:password@host.neon.tech/database?sslmode=require

# Supabase (兼容层/备份，可选)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------------------ 对象存储配置 ------------------
# 阿里 OSS (图片/PDF存储)
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=your-bucket-name
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_CDN_DOMAIN=https://cdn.yourdomain.com

# ------------------ AI 服务配置 ------------------
AI_API_KEY=your-ai-api-key
AI_ENDPOINT=https://api-inference.modelscope.cn/v1/chat/completions
AI_MODEL=Qwen/Qwen3-VL-8B-Instruct

# ------------------ Redis 配置 (BullMQ) ------------------
# 支持两种格式：
# 1. URL格式 (推荐): REDIS_URL=redis://default:password@host:port
# 2. 分开配置: REDIS_HOST + REDIS_PORT + REDIS_PASSWORD
REDIS_URL=redis://default:password@your-redis-host.upstash.io:6379
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# ------------------ 服务器配置 ------------------
PORT=3001
NODE_ENV=development

# ------------------ 任务队列配置 ------------------
MAX_RETRIES=3
TASK_TIMEOUT_MS=1800000
CONCURRENCY=2
