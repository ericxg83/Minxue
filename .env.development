# ============================================
# 敏学App V3 前端开发环境配置
# 本地开发时使用 (npm run dev)
# ============================================

# ------------------ API 配置 ------------------
# 后端 API 地址（开发环境通过 Vite 代理，留空即可）
VITE_API_URL=

# ------------------ OSS CDN 配置 ------------------
# 阿里 OSS CDN 域名（用于图片加速）
VITE_OSS_CDN_DOMAIN=https://cdn.yourdomain.com

# ------------------ Supabase 配置 (兼容层) ------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your-anon-key

# ------------------ AI 服务配置 ------------------
VITE_AI_API_KEY=your-ai-api-key
VITE_AI_ENDPOINT=https://api-inference.modelscope.cn/v1/chat/completions
VITE_AI_MODEL=Qwen/Qwen3-VL-8B-Instruct

# ------------------ 应用环境标识 ------------------
VITE_APP_ENV=development
