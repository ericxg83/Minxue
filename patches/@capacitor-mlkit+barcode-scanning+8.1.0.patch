+    private static class ScanOverlay extends View {
+        private final Paint overlayPaint;
+        private final Paint cornerPaint;
+        private final RectF scanRect;
+        private final float cornerLength = 40;
+
+        public ScanOverlay(Context context) {
+            super(context);
+            overlayPaint = new Paint();
+            overlayPaint.setColor(Color.argb(180, 0, 0, 0));
+            overlayPaint.setAntiAlias(true);
+            overlayPaint.setStyle(Paint.Style.FILL);
+
+            cornerPaint = new Paint();
+            cornerPaint.setColor(Color.WHITE);
+            cornerPaint.setStrokeWidth(5);
+            cornerPaint.setStyle(Paint.Style.STROKE);
+            cornerPaint.setAntiAlias(true);
+
+            scanRect = new RectF();
+        }
+
+        @Override
+        protected void onSizeChanged(int w, int h, int oldw, int oldh) {
+            super.onSizeChanged(w, h, oldw, oldh);
+            int scanSize = (int) (Math.min(w, h) * 0.65f);
+            int left = (w - scanSize) / 2;
+            int top = (int) ((h - scanSize) / 2 * 0.85f);
+            scanRect.set(left, top, left + scanSize, top + scanSize);
+        }
+
+        @Override
+        protected void onDraw(Canvas canvas) {
+            super.onDraw(canvas);
+            // Draw semi-transparent overlay with a hole in the scan area
+            Path path = new Path();
+            path.addRect(new RectF(0, 0, getWidth(), getHeight()), Path.Direction.CW);
+            path.addRoundRect(scanRect, 20, 20, Path.Direction.CCW);
+            canvas.drawPath(path, overlayPaint);
+
+            // Draw corner marks
+            float l = scanRect.left, t = scanRect.top, r = scanRect.right, b = scanRect.bottom, cl = cornerLength;
+            canvas.drawLine(l, t, l + cl, t, cornerPaint);
+            canvas.drawLine(l, t, l, t + cl, cornerPaint);
+            canvas.drawLine(r, t, r - cl, t, cornerPaint);
+            canvas.drawLine(r, t, r, t + cl, cornerPaint);
+            canvas.drawLine(l, b, l + cl, b, cornerPaint);
+            canvas.drawLine(l, b, l, b - cl, cornerPaint);
+            canvas.drawLine(r, b, r - cl, b, cornerPaint);
+            canvas.drawLine(r, b, r, b - cl, cornerPaint);
+        }
+    }
